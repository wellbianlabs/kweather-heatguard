# ── 케이웨더 IoT Open API (실 수집) ──
# 키를 비우면 자동으로 mock 모드(키 없이 PoC 구동).
KW_IOT_API_KEY=
KW_IOT_USER_ID=test1@kweather.co.kr
# KW_IOT_BASE_URL=https://gateway.kweather.co.kr:8443/iot/groups/v2

# mock 강제(키가 있어도 합성 데이터로 시연)
USE_MOCK=true

# 수집 주기(초)
POLL_INTERVAL_SEC=5

# ── 경보(Slack/Webhook 1채널) ──
# 비우면 경보를 WS 피드/로그로만 송출.
SLACK_WEBHOOK_URL=
ALERT_DEBOUNCE_SEC=600

# ── 위험단계 임계(체감℃) — 기본값이 STS와 동일, 보통 변경 불필요 ──
# HEAT_ATTENTION=31
# HEAT_CAUTION=33
# HEAT_WARNING=35
# HEAT_DANGER=38
